---
import Layout from '../layouts/Layout.astro';
import Head from '../components/layout/Head.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import Breadcrumbs from '../components/common/Breadcrumbs.astro';
import Button from '../components/ui/Button.astro';
import Card from '../components/ui/Card.astro';
import { sanity } from '../lib/sanity';
import { createPageUrl } from '../lib/utils';
import { DEFAULT_STATS, type Statistic } from '../lib/defaultContent';

const services = sanity ? await sanity.fetch(`*[_type == "service"] | order(_createdAt asc)`).catch(() => []) : [];
const statsData = sanity ? await sanity.fetch(`*[_type == "statistic" && page == "solutions"] | order(order asc)`).catch(() => []) : [];
const heroSolutions = sanity ? await sanity.fetch(`*[_type == "hero" && page == "solutions"] | order(_updatedAt desc)[0]{ heading, subheading, ctaLabel }`).catch(() => null) : null;

const stats: Statistic[] = statsData.length > 0 ? statsData : DEFAULT_STATS;

const pathwaySteps = [
  {
    label: 'Discover',
    color: 'from-blue-500 to-blue-600',
    items: ['Speaking Events', 'LEAP through Lunch', 'Workshops'],
  },
  {
    label: 'Experience',
    color: 'from-purple-500 to-purple-600',
    items: ['Team Building/Development Experiences'],
  },
  {
    label: 'Develop',
    color: 'from-amber-500 to-amber-600',
    items: ['Coaching', 'Leadership Programs'],
  },
  {
    label: 'Transform',
    color: 'from-emerald-500 to-emerald-600',
    items: ['Consulting', 'Organizational Performance Systems'],
  },
];

const quickLinks = [
  { text: 'I want to LEAP through Lunch', anchor: '#leap-through-lunch' },
  { text: 'I want to engage a LEAP speaker', anchor: '#keynote-presentations' },
  { text: 'I want to grow as an executive', anchor: '#executive-coaching' },
  { text: 'I want to grow my leaders', anchor: '#leadership-coaching-series' },
  { text: 'I want to strengthen my team', anchor: '#team-development' },
  { text: 'I want to improve our leadership systems', anchor: '#performance-management' },
  { text: 'I want to improve leadership hiring', anchor: '#hiring-framework' },
];

const coachingPathway = [
  {
    title: 'Leading Self',
    description: 'Develop self-awareness, personal accountability, and the mindset required to lead effectively. Build the foundation every leader needs.',
  },
  {
    title: 'Leading Others',
    description: 'Learn to communicate expectations, build trust, provide feedback, and develop the people around you into high performers.',
  },
  {
    title: 'Leading Tasks & Projects',
    description: 'Master the practices of planning, prioritizing, delegating, and executing with excellence. Turn strategy into daily action.',
  },
  {
    title: 'Leading Change',
    description: 'Guide teams and organizations through transitions with clarity, confidence, and commitment. Build cultures that embrace improvement.',
  },
  {
    title: 'LEAP Coaching Certification',
    description: 'Become a certified LEAP coach and bring the framework to your organization or practice. Expand your leadership impact.',
  },
];

const signatureEngagements = [
  {
    title: 'LEAP Leadership Development',
    features: [
      'Structured coaching series',
      'Leading Self through Leading Change',
      'Individual and group formats',
      'Practical application between sessions',
      'Progress tracking and measurement',
    ],
    color: 'from-blue-500 to-blue-600',
    anchor: '#leadership-coaching-series',
  },
  {
    title: 'Executive Coaching',
    features: [
      'Strategic leadership advisory',
      'One-on-one senior leader focus',
      'Decision-making and alignment',
      'Executive communication',
      'Organizational performance',
    ],
    color: 'from-purple-500 to-purple-600',
    anchor: '#executive-coaching',
  },
  {
    title: 'Organizational Consulting',
    features: [
      'Performance assessments',
      'Leadership structure design',
      'Accountability frameworks',
      'Operational improvement',
      'Culture alignment',
    ],
    color: 'from-emerald-500 to-emerald-600',
    anchor: '#performance-management',
  },
];
---

<Layout>
  <Head slot="head" title="LEAP Solutions" description="Turning leadership philosophy into measurable progress. Comprehensive solutions for leadership development, executive coaching, and organizational performance." />
  <Header />
  <main id="main-content" class="min-h-screen bg-gradient-to-br from-slate-50 to-white">

    <!-- Hero Section -->
    <section class="relative pt-32 pb-20 overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-br from-primary/5 to-accent/5" />
      <div class="max-w-7xl mx-auto px-6 lg:px-8 relative z-10">
        <Breadcrumbs items={[{ label: 'Solutions' }]} />

        <div class="text-center max-w-4xl mx-auto">
          <span class="animate-fadeUp text-primary font-semibold text-sm tracking-wider uppercase mb-4 block">
            LEAP Solutions
          </span>
          <h1 class="animate-fadeUp text-4xl sm:text-5xl lg:text-6xl font-bold text-primary mb-6" style="animation-delay: 0.1s;">
            {heroSolutions?.heading ?? 'Turning Leadership Philosophy Into Measurable Progress'}
          </h1>
          <p class="animate-fadeUp text-xl text-slate-600 leading-relaxed mb-8" style="animation-delay: 0.2s;">
            {heroSolutions?.subheading ?? "Organizations everywhere are striving to strengthen leadership, improve accountability, and achieve better results. Yet many struggle to translate these goals into consistent daily practices. The LEAP philosophy helps close that gap."}
          </p>
          <div class="animate-fadeUp flex flex-col sm:flex-row gap-4 justify-center" style="animation-delay: 0.3s;">
            <Button href={createPageUrl('ScheduleCall')} size="lg">
              {heroSolutions?.ctaLabel ?? 'Schedule a Leadership Conversation'}
            </Button>
            <Button href={createPageUrl('Practice')} variant="secondary" size="lg">
              Take the Assessment
            </Button>
          </div>
        </div>
      </div>
    </section>

    <!-- Stats Banner -->
    <section class="py-12 bg-gradient-to-br from-primary to-primary-dark">
      <div class="max-w-7xl mx-auto px-6 lg:px-8">
        <div class="grid grid-cols-2 lg:grid-cols-4 gap-8">
          {stats.map((stat, i) => (
            <div class={`reveal stagger-${i + 1} text-center`}>
              <p class="text-4xl lg:text-5xl font-bold text-white mb-2">{stat.value}</p>
              <p class="text-slate-200 text-sm lg:text-base">{stat.label}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Where Should You Start? Pathway Section -->
    <section class="py-20">
      <div class="max-w-7xl mx-auto px-6 lg:px-8">
        <div class="reveal text-center mb-16">
          <h2 class="text-4xl font-bold text-primary mb-4">Where Should You Start?</h2>
          <p class="text-xl text-slate-600 max-w-3xl mx-auto">
            Every organization is at a different stage. Find your entry point and build from there.
          </p>
        </div>

        <div class="grid md:grid-cols-4 gap-6 relative">
          <!-- Connecting line (hidden on mobile) -->
          <div class="hidden md:block absolute top-16 left-[12.5%] right-[12.5%] h-1 bg-gradient-to-r from-blue-500 via-purple-500 via-amber-500 to-emerald-500 rounded-full z-0" />

          {pathwaySteps.map((step, i) => (
            <div class={`reveal stagger-${i + 1} text-center relative z-10`}>
              <div class={`w-32 h-32 rounded-full bg-gradient-to-br ${step.color} flex items-center justify-center mx-auto mb-6 shadow-xl`}>
                <span class="text-white text-2xl font-bold">{step.label}</span>
              </div>
              <ul class="space-y-2">
                {step.items.map((item) => (
                  <li class="text-slate-600 text-sm">{item}</li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Quick Links Section -->
    <section class="py-16 bg-slate-50">
      <div class="max-w-5xl mx-auto px-6 lg:px-8">
        <div class="reveal text-center mb-12">
          <h2 class="text-3xl font-bold text-primary mb-4">What Are You Looking For?</h2>
          <p class="text-lg text-slate-600">Jump directly to the solution that fits your needs.</p>
        </div>

        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
          {quickLinks.map((link, i) => (
            <a href={link.anchor} class={`reveal stagger-${Math.min(i + 1, 6)} group flex items-center gap-3 bg-white rounded-xl p-5 shadow-sm border border-slate-100 hover:shadow-lg hover:border-primary/20 transition-all`}>
              <div class="w-10 h-10 rounded-full bg-primary/10 flex items-center justify-center flex-shrink-0 group-hover:bg-primary/20 transition-colors">
                <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
                </svg>
              </div>
              <span class="text-slate-700 font-medium group-hover:text-primary transition-colors">{link.text}</span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- LEAP Through Lunch Section -->
    <section id="leap-through-lunch" class="py-20">
      <div class="max-w-7xl mx-auto px-6 lg:px-8">
        <div class="grid lg:grid-cols-2 gap-12 items-start">
          <div class="reveal">
            <span class="text-primary font-semibold text-sm tracking-wider uppercase mb-4 block">Complimentary by Invitation</span>
            <h2 class="text-4xl font-bold text-primary mb-4">LEAP Through Lunch</h2>
            <p class="text-2xl text-slate-700 font-medium mb-2">A leadership conversation worth having.</p>
            <p class="text-slate-500 italic mb-8">Complimentary by invitation / qualified organizations.</p>

            <div class="space-y-6 mb-8">
              <div>
                <h3 class="text-lg font-bold text-primary mb-3">Session Format</h3>
                <div class="grid grid-cols-2 gap-3">
                  {['Up to 5 participants', 'Hosted at your office or restaurant', 'Lunch included', '60-75 minutes'].map((item) => (
                    <div class="flex items-center gap-2">
                      <svg class="w-5 h-5 text-emerald-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                      </svg>
                      <span class="text-slate-700 text-sm">{item}</span>
                    </div>
                  ))}
                </div>
              </div>

              <div>
                <h3 class="text-lg font-bold text-primary mb-3">What Happens During the Session</h3>
                <ul class="space-y-2">
                  {['The LEAP philosophy and why it works', 'Why leadership systems matter more than programs', 'Common gaps organizations face', 'Practical ways to start improving today'].map((item) => (
                    <li class="flex items-start gap-2">
                      <svg class="w-5 h-5 text-primary flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4" />
                      </svg>
                      <span class="text-slate-600">{item}</span>
                    </li>
                  ))}
                </ul>
              </div>
            </div>
          </div>

          <Card class="reveal stagger-2 p-8">
            <h3 class="text-lg font-bold text-primary mb-4">Ideal For</h3>
            <p class="text-slate-600 mb-6">
              Organizations exploring leadership development, executive coaching, team alignment, or culture improvement. If you are considering investing in your leaders, this is a great place to start the conversation.
            </p>
            <div class="bg-primary/5 rounded-xl p-6 mb-6">
              <p class="text-primary font-semibold text-center text-lg">No cost. No obligation. Just a meaningful conversation about leadership.</p>
            </div>
            <Button href={createPageUrl('ScheduleCall')} size="lg" class="w-full">
              Schedule a Leadership Lunch
            </Button>
          </Card>
        </div>
      </div>
    </section>

    <!-- LEAP Keynote Presentations & Leadership Sessions -->
    <section id="keynote-presentations" class="py-20 bg-slate-50">
      <div class="max-w-7xl mx-auto px-6 lg:px-8">
        <div class="reveal text-center mb-12">
          <span class="text-primary font-semibold text-sm tracking-wider uppercase mb-4 block">Speaking & Presentations</span>
          <h2 class="text-4xl font-bold text-primary mb-4">LEAP Keynote Presentations & Leadership Sessions</h2>
          <p class="text-xl text-slate-600 max-w-3xl mx-auto">
            Custom engagements designed to challenge thinking, inspire action, and equip leaders with practical tools they can use immediately.
          </p>
        </div>

        <div class="grid lg:grid-cols-2 gap-12">
          <div class="reveal">
            <h3 class="text-xl font-bold text-primary mb-4">Focus Areas</h3>
            <div class="space-y-3 mb-8">
              {[
                'The LEAP Framework: Leadership, Effectiveness, Accountability, Productivity',
                'Strengthening leadership mindset and daily practices',
                'Creating cultures of accountability without micromanagement',
                'Aligning teams around shared expectations and outcomes',
                'Practical behaviors that drive measurable results',
                'Translating leadership principles into repeatable systems',
              ].map((item) => (
                <div class="flex items-start gap-3">
                  <svg class="w-5 h-5 text-emerald-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                  </svg>
                  <span class="text-slate-700">{item}</span>
                </div>
              ))}
            </div>
          </div>

          <div class="reveal stagger-2">
            <Card class="p-8">
              <h3 class="text-lg font-bold text-primary mb-4">Organizations Often Engage When They Say:</h3>
              <ul class="space-y-3 mb-6">
                {[
                  '"We need a speaker who delivers more than motivation."',
                  '"Our leaders need practical tools, not just theory."',
                  '"We want our team to leave with something they can actually use."',
                  '"We are looking for someone who understands real-world leadership challenges."',
                ].map((item) => (
                  <li class="flex items-start gap-2">
                    <svg class="w-5 h-5 text-accent flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
                    </svg>
                    <span class="text-slate-600 italic">{item}</span>
                  </li>
                ))}
              </ul>

              <div class="border-t border-slate-200 pt-6">
                <h4 class="text-sm font-bold text-slate-500 uppercase mb-3">Ideal For</h4>
                <p class="text-slate-600 mb-6">Conferences, organizational meetings, leadership events, and executive retreats.</p>
                <Button href={createPageUrl('Investment')} size="lg" class="w-full">
                  View Speaking Engagement Options
                </Button>
              </div>
            </Card>
          </div>
        </div>
      </div>
    </section>

    <!-- Executive Coaching Section -->
    <section id="executive-coaching" class="py-20">
      <div class="max-w-7xl mx-auto px-6 lg:px-8">
        <div class="grid lg:grid-cols-2 gap-12 items-start">
          <div class="reveal">
            <span class="text-primary font-semibold text-sm tracking-wider uppercase mb-4 block">Executive Coaching</span>
            <h2 class="text-4xl font-bold text-primary mb-4">Strategic Leadership Advisory for Senior Leaders</h2>
            <p class="text-xl text-slate-600 leading-relaxed mb-8">
              One-on-one coaching for executives and senior leaders focused on the challenges that matter most at the top.
            </p>

            <h3 class="text-xl font-bold text-primary mb-4">Focus Areas</h3>
            <div class="space-y-3 mb-8">
              {[
                'Strategic decision-making and clarity',
                'Leadership team alignment and performance',
                'Organizational performance and culture',
                'Executive communication and presence',
                'Guiding teams and organizations through change',
              ].map((item) => (
                <div class="flex items-start gap-3">
                  <svg class="w-5 h-5 text-emerald-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                  </svg>
                  <span class="text-slate-700">{item}</span>
                </div>
              ))}
            </div>
          </div>

          <div class="reveal stagger-2">
            <Card class="p-8">
              <h3 class="text-lg font-bold text-primary mb-4">Leaders Often Engage When They Say:</h3>
              <ul class="space-y-3 mb-6">
                {[
                  '"I need a sounding board who understands what I am facing."',
                  '"I want to be more intentional about how I lead."',
                  '"I need help aligning my leadership team."',
                  '"I want to leave a lasting leadership legacy."',
                  '"I am navigating a major transition and need perspective."',
                ].map((item) => (
                  <li class="flex items-start gap-2">
                    <svg class="w-5 h-5 text-accent flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
                    </svg>
                    <span class="text-slate-600 italic">{item}</span>
                  </li>
                ))}
              </ul>

              <div class="border-t border-slate-200 pt-6">
                <h4 class="text-sm font-bold text-slate-500 uppercase mb-3">Ideal For</h4>
                <p class="text-slate-600 mb-6">Executives, directors, and senior leaders seeking focused, strategic coaching.</p>
                <Button href={createPageUrl('Investment')} size="lg" class="w-full">
                  View Executive Coaching Options
                </Button>
              </div>
            </Card>
          </div>
        </div>
      </div>
    </section>

    <!-- The LEAP Leadership Coaching Series -->
    <section id="leadership-coaching-series" class="py-20 bg-slate-50">
      <div class="max-w-7xl mx-auto px-6 lg:px-8">
        <div class="reveal text-center mb-12">
          <span class="text-primary font-semibold text-sm tracking-wider uppercase mb-4 block">Structured Development</span>
          <h2 class="text-4xl font-bold text-primary mb-4">The LEAP Leadership Coaching Series</h2>
          <p class="text-xl text-slate-600 max-w-3xl mx-auto">
            A structured pathway that develops leaders from personal mastery to organizational impact.
          </p>
        </div>

        <!-- Coaching Pathway -->
        <div class="grid md:grid-cols-5 gap-4 mb-12">
          {coachingPathway.map((step, i) => (
            <Card class={`reveal stagger-${Math.min(i + 1, 6)} p-6 text-center hover:shadow-xl transition-all h-full flex flex-col`}>
              <div class="w-12 h-12 rounded-full bg-gradient-to-br from-primary to-primary-dark flex items-center justify-center mx-auto mb-4 shadow-lg">
                <span class="text-white font-bold text-lg">{i + 1}</span>
              </div>
              <h3 class="text-lg font-bold text-primary mb-3">{step.title}</h3>
              <p class="text-slate-600 text-sm flex-grow">{step.description}</p>
            </Card>
          ))}
        </div>

        <div class="grid lg:grid-cols-2 gap-8">
          <Card class="reveal p-8">
            <h3 class="text-lg font-bold text-primary mb-4">Leaders Often Engage When They Say:</h3>
            <ul class="space-y-3">
              {[
                '"I want to develop as a leader, not just attend a training."',
                '"I need a structured path, not a one-time event."',
                '"I want to grow my ability to lead people, not just manage tasks."',
                '"I want to build habits that last beyond a workshop."',
              ].map((item) => (
                <li class="flex items-start gap-2">
                  <svg class="w-5 h-5 text-accent flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
                  </svg>
                  <span class="text-slate-600 italic">{item}</span>
                </li>
              ))}
            </ul>
          </Card>

          <div class="reveal stagger-2 flex flex-col justify-center">
            <div class="bg-gradient-to-br from-primary to-primary-dark rounded-2xl p-8 text-white text-center">
              <h3 class="text-2xl font-bold mb-4">Ready to Start the Journey?</h3>
              <p class="text-slate-200 mb-6">Explore the full coaching series pathway and investment considerations.</p>
              <Button href={createPageUrl('Investment')} variant="outline" size="lg" class="bg-white/10 border-2 border-white/30 text-white hover:bg-white/20">
                View Investment Considerations
              </Button>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- LEAP Coaching Certification -->
    <section id="coaching-certification" class="py-20">
      <div class="max-w-7xl mx-auto px-6 lg:px-8">
        <div class="grid lg:grid-cols-2 gap-12 items-center">
          <div class="reveal">
            <span class="text-primary font-semibold text-sm tracking-wider uppercase mb-4 block">Certification Program</span>
            <h2 class="text-4xl font-bold text-primary mb-4">LEAP Coaching Certification</h2>
            <p class="text-xl text-slate-600 leading-relaxed mb-6">
              Become a certified LEAP coach and bring the framework into your organization, your practice, or your community. The certification program equips you to facilitate the LEAP coaching process with confidence and credibility.
            </p>
            <p class="text-slate-600 leading-relaxed mb-8">
              Designed for internal coaches, HR leaders, consultants, and leadership practitioners who want to expand their toolkit with a proven framework for developing leaders at every level.
            </p>
            <div class="flex flex-col sm:flex-row gap-4">
              <Button href={createPageUrl('ScheduleCall')} size="lg">
                Learn About Certification
              </Button>
              <Button href={createPageUrl('Investment')} variant="secondary" size="lg">
                Investment Considerations
              </Button>
            </div>
          </div>

          <div class="reveal stagger-2">
            <Card class="p-8">
              <div class="w-20 h-20 rounded-2xl bg-gradient-to-br from-primary to-primary-dark flex items-center justify-center mx-auto mb-6 shadow-lg">
                <svg class="w-10 h-10" fill="none" stroke="white" stroke-width="2" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z" />
                </svg>
              </div>
              <h3 class="text-xl font-bold text-primary text-center mb-4">What Certification Includes</h3>
              <div class="space-y-3">
                {[
                  'Full LEAP coaching methodology training',
                  'Practice facilitation and mentoring',
                  'Certification materials and resources',
                  'Ongoing support and community access',
                  'License to deliver LEAP coaching',
                ].map((item) => (
                  <div class="flex items-center gap-3">
                    <svg class="w-5 h-5 text-emerald-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
