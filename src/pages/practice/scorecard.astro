---
import Layout from '../../layouts/Layout.astro';
import Head from '../../components/layout/Head.astro';
import Header from '../../components/layout/Header.astro';
import Footer from '../../components/layout/Footer.astro';
import LeadershipScorecard from '../../components/islands/LeadershipScorecard';
import type { ScorecardSectionProp } from '../../components/islands/LeadershipScorecard';
import type { CaptchaConfig } from '../../components/islands/AssessmentFlow';
import { createPageUrl } from '../../lib/utils';
import { sanity } from '../../lib/sanity';
import { DEFAULT_SCORECARD_SECTIONS } from '../../lib/defaultContent';

type SanitySlug = { current?: string } | string;
type RawQ = { text?: string; order?: number };
type RawSec = {
  title?: string;
  key?: SanitySlug;
  order?: number;
  questions?: RawQ[];
};

function slugVal(k: SanitySlug | undefined): string {
  if (!k) return '';
  return typeof k === 'string' ? k : (k.current ?? '');
}

function normalizeSections(raw: RawSec[]): ScorecardSectionProp[] {
  return [...raw]
    .filter((d) => d.title && d.key)
    .sort((a, b) => (a.order ?? 0) - (b.order ?? 0))
    .map((d) => ({
      title: d.title as string,
      key: slugVal(d.key as SanitySlug),
      questions: [...(d.questions ?? [])]
        .sort((a, b) => (a.order ?? 0) - (b.order ?? 0))
        .map((q) => q.text ?? '')
        .filter((t) => t.length > 0),
    }))
    .filter((s) => s.key.length > 0 && s.questions.length > 0);
}

const rawSecs = sanity
  ? await sanity
      .fetch<RawSec[]>(
        `*[_type == "scorecardSection"] | order(order asc) { title, key, order, questions[]{ text, order } }`,
      )
      .catch(() => [])
  : [];
const normalized = normalizeSections(rawSecs);
const scorecardSections: ScorecardSectionProp[] =
  normalized.length > 0
    ? normalized
    : DEFAULT_SCORECARD_SECTIONS.map((sec) => ({
        title: sec.title,
        key: sec.key,
        questions: sec.questions.map((q) => q.text),
      }));

const settings = sanity
  ? await sanity
      .fetch<{ captchaEnabled?: boolean; hcaptchaSiteKey?: string } | null>(
        `*[_type == "assessmentSettings"][0]{ captchaEnabled, hcaptchaSiteKey }`,
      )
      .catch(() => null)
  : null;

const captchaConfig: CaptchaConfig | undefined = settings?.captchaEnabled
  ? { enabled: true, siteKey: settings.hcaptchaSiteKey }
  : undefined;
---

<Layout>
  <Head slot="head" title="Leadership Role Scorecard Assessment" description="Evaluate whether a leadership role in your organization is positioned for success with this quick scorecard assessment." />
  <Header />
  <main id="main-content" class="min-h-screen bg-gradient-to-br from-slate-50 to-white pt-24 pb-16">
    <div class="max-w-6xl mx-auto px-6 lg:px-8">
      <div class="text-center mb-12">
        <a
          href={createPageUrl('Practice')}
          class="inline-flex items-center gap-2 text-slate-500 hover:text-slate-700 mb-6 transition-colors"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
          </svg>
          Back to Practice
        </a>

        <span class="block text-primary font-semibold text-sm tracking-wider uppercase mb-4">
          Leadership Assessment
        </span>
        <h1 class="text-3xl lg:text-4xl font-bold text-primary mb-4">
          Leadership Role Scorecard
        </h1>
        <p class="text-lg text-slate-600 max-w-2xl mx-auto mb-2">
          Is this leadership role designed for success? Many leadership challenges are not caused by the leader — they are caused by unclear role design.
        </p>
        <p class="text-sm text-slate-500 max-w-xl mx-auto">
          20 questions &bull; 4 sections &bull; Takes about 5 minutes
        </p>
      </div>

      <LeadershipScorecard client:load sections={scorecardSections} captchaConfig={captchaConfig} />
    </div>
  </main>
  <Footer />
</Layout>
