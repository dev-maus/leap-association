---
import Layout from '../../layouts/Layout.astro';
import Head from '../../components/layout/Head.astro';
import Header from '../../components/layout/Header.astro';
import Footer from '../../components/layout/Footer.astro';
import Card from '../../components/ui/Card.astro';
import Badge from '../../components/ui/Badge.astro';
import Button from '../../components/ui/Button.astro';
import NewsletterForm from '../../components/islands/NewsletterForm';
import { sanity } from '../../lib/sanity';
import { urlFor, urlForFile } from '../../lib/sanity';
import { createPageUrl } from '../../lib/utils';
import { DEFAULT_BOOKS, type Book } from '../../lib/defaultContent';

const blogPosts = sanity ? await sanity.fetch(`*[_type == "blogPost" && status == "published"] | order(publishedAt desc)[0...12]`).catch(() => []) : [];
const videos = sanity ? await sanity.fetch(`*[_type == "video" && status == "published"] | order(_createdAt desc)[0...12]`).catch(() => []) : [];
const downloads = sanity ? await sanity.fetch(`*[_type == "download" && status == "published"] | order(_createdAt desc)[0...12]{
  _id,
  title,
  description,
  type,
  fileSize,
  status,
  "file": file.asset->{
    _id,
    _ref,
    url,
    originalFilename,
    size,
    mimeType
  }
}`).catch(() => []) : [];
const books = sanity ? await sanity.fetch(`*[_type == "book" && status == "published"] | order(_createdAt desc)[0...6]`).catch(() => []) : [];

// Extract unique categories from blog posts
const categories = [...new Set(blogPosts.map((post: any) => post.category).filter(Boolean))];

const displayBooks: Book[] = books.length > 0 ? books : DEFAULT_BOOKS;
const heroResources = sanity ? await sanity.fetch(`*[_type == "hero" && page == "resources"][0]{ heading, subheading }`).catch(() => null) : null;

const pulseData = [
  { label: 'Strengthening leadership accountability', pct: 31 },
  { label: 'Improving team communication', pct: 24 },
  { label: 'Developing emerging leaders', pct: 18 },
  { label: 'Aligning leadership expectations', pct: 12 },
  { label: 'Improving performance management systems', pct: 9 },
  { label: 'Hiring and retaining strong leaders', pct: 6 },
];
---

<Layout>
  <Head slot="head" title="Leadership Insights" description="Leadership insights, tools, and perspectives drawn from real-world experiences across organizations and industries." />
  <Header />
  <main id="main-content" class="min-h-screen bg-gradient-to-br from-slate-50 to-white pt-24 pb-16">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <!-- Header -->
      <div class="text-center mb-16">
        <a
          href={createPageUrl('Home')}
          class="inline-flex items-center gap-2 text-slate-500 hover:text-slate-700 mb-6 transition-colors"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
          </svg>
          Back to Home
        </a>

        <span class="block text-primary font-semibold text-sm tracking-wider uppercase mb-4">
          Leadership Insights
        </span>
        <h1 class="text-4xl lg:text-5xl font-bold text-primary mb-6">
          {heroResources?.heading ?? 'Leadership Insights'}
        </h1>
        <p class="text-xl text-slate-600 max-w-3xl mx-auto leading-relaxed">
          {heroResources?.subheading ?? 'Leadership is shaped by the practices leaders develop and apply consistently over time. The Leadership Insights hub shares ideas, tools, and leadership perspectives drawn from real-world experiences across organizations and industries.'}
        </p>
      </div>

      <!-- Articles and Ideas Section -->
      <section class="mb-20">
        <div class="flex items-center gap-4 mb-8">
          <div class="w-14 h-14 rounded-2xl bg-primary/10 flex items-center justify-center">
            <svg class="w-7 h-7 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
            </svg>
          </div>
          <div>
            <h2 class="text-3xl font-bold text-primary">Articles and Ideas</h2>
            <p class="text-slate-600">Leadership insights explore practical leadership concepts that help individuals and organizations strengthen communication, accountability, and performance.</p>
          </div>
        </div>

        <!-- Category Filter Buttons -->
        {categories.length > 0 && (
          <div class="flex flex-wrap gap-3 mb-8" id="category-filters">
            <button
              data-category="all"
              class="category-btn px-4 py-2 bg-primary text-white rounded-full text-sm font-medium hover:bg-primary-dark transition-colors"
            >
              All Articles
            </button>
            {categories.map((category: string) => (
              <button
                data-category={category}
                class="category-btn px-4 py-2 bg-slate-100 text-slate-700 rounded-full text-sm font-medium hover:bg-slate-200 transition-colors"
              >
                {category}
              </button>
            ))}
          </div>
        )}

        <div id="blog-posts-grid" class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
          {blogPosts.map((post: any) => (
            <a href={`/resources/blog/${post.slug}`} class="blog-post-card" data-category={post.category || 'uncategorized'}>
              <Card class="p-6 hover:border-primary hover:shadow-lg transition-all cursor-pointer group h-full">
                {post.category && (
                  <Badge variant="primary" class="mb-3">
                    {post.category}
                  </Badge>
                )}
                <h3 class="text-xl font-bold text-slate-900 mb-3 group-hover:text-primary transition-colors">
                  {post.title}
                </h3>
                <p class="text-slate-600 mb-4 leading-relaxed">
                  {post.excerpt}
                </p>
                <div class="flex items-center justify-between text-sm text-slate-500">
                  <span>{post.publishedAt ? new Date(post.publishedAt).toLocaleDateString() : ''}</span>
                  <span>{post.readTime || 5} min read</span>
                </div>
              </Card>
            </a>
          ))}
        </div>
      </section>

      <!-- Videos Section -->
      <section class="mb-20">
        <div class="flex items-center gap-4 mb-8">
          <div class="w-14 h-14 rounded-2xl bg-accent/10 flex items-center justify-center">
            <svg class="w-7 h-7 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z" />
            </svg>
          </div>
          <div>
            <h2 class="text-3xl font-bold text-primary">Videos</h2>
            <p class="text-slate-600">Watch, learn, and get inspired</p>
          </div>
        </div>

        <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
          {videos.map((video: any) => (
            <a href={`/resources/video/${video._id}`}>
              <Card class="overflow-hidden hover:border-accent hover:shadow-lg transition-all cursor-pointer group">
                <div class="relative h-40 overflow-hidden bg-slate-100">
                  {video.thumbnail ? (
                    <img
                      src={urlFor(video.thumbnail)?.width(400).height(300).url()}
                      alt={video.title}
                      class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-300"
                    />
                  ) : (
                    <div class="w-full h-full flex items-center justify-center bg-slate-200">
                      <svg class="w-12 h-12 text-slate-400" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M8 5v14l11-7z" />
                      </svg>
                    </div>
                  )}
                  <div class="absolute inset-0 bg-black/40 flex items-center justify-center">
                    <div class="w-14 h-14 rounded-full bg-white/90 flex items-center justify-center group-hover:scale-110 transition-transform">
                      <svg class="w-6 h-6 text-accent ml-1" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M8 5v14l11-7z" />
                      </svg>
                    </div>
                  </div>
                  {video.duration && (
                    <span class="absolute top-3 right-3 px-2 py-1 bg-black/70 text-white text-xs rounded">
                      {video.duration}
                    </span>
                  )}
                </div>
                <div class="p-4">
                  {video.type && (
                    <Badge variant="accent" class="mb-2">
                      {video.type}
                    </Badge>
                  )}
                  <h3 class="font-bold text-slate-900 group-hover:text-accent transition-colors">
                    {video.title}
                  </h3>
                </div>
              </Card>
            </a>
          ))}
        </div>
      </section>

      <!-- Downloads Section -->
      <section class="mb-20">
        <div class="flex items-center gap-4 mb-8">
          <div class="w-14 h-14 rounded-2xl bg-primary/10 flex items-center justify-center">
            <svg class="w-7 h-7 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
            </svg>
          </div>
          <div>
            <h2 class="text-3xl font-bold text-primary">Downloads</h2>
            <p class="text-slate-600">Free tools, templates, and guides</p>
          </div>
        </div>

        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
          {downloads.map((item: any) => (
            <Card class="p-6 hover:border-primary hover:shadow-lg transition-all group">
              <div class="flex items-start gap-4 mb-4">
                <div class="w-12 h-12 rounded-xl bg-primary/10 flex items-center justify-center flex-shrink-0 group-hover:scale-110 transition-transform">
                  <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                  </svg>
                </div>
                <div class="flex-1">
                  <h3 class="font-bold text-slate-900 mb-1 group-hover:text-primary transition-colors">
                    {item.title}
                  </h3>
                  <div class="flex items-center justify-between text-sm text-slate-500">
                    <span>{item.type}</span>
                    {item.fileSize && <span>{item.fileSize}</span>}
                  </div>
                </div>
              </div>
              {item.description && (
                <p class="text-sm text-slate-600 mb-4">{item.description}</p>
              )}
              {item.file && urlForFile(item.file) && (
                <a href={urlForFile(item.file) || '#'} download>
                  <Button variant="outline" size="sm" class="w-full">
                    <svg class="w-4 h-4 mr-2 inline" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                    </svg>
                    Download
                  </Button>
                </a>
              )}
            </Card>
          ))}
        </div>
      </section>

      <!-- Books Section -->
      <section class="mb-20">
        <div class="flex items-center gap-4 mb-8">
          <div class="w-14 h-14 rounded-2xl bg-accent/10 flex items-center justify-center">
            <svg class="w-7 h-7 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
            </svg>
          </div>
          <div>
            <h2 class="text-3xl font-bold text-primary">Books</h2>
            <p class="text-slate-600">Deepen your understanding with these essential reads</p>
          </div>
        </div>

        <div class="space-y-8">
          {displayBooks.map((book: any) => (
            <Card class="p-8 lg:p-10">
              <div class="grid lg:grid-cols-3 gap-8 items-center">
                <!-- Book Cover -->
                <div class="lg:col-span-1">
                  {book.coverUrl || book.cover ? (
                    <img
                      src={book.cover ? urlFor(book.cover)?.width(300).height(450).url() : book.coverUrl}
                      alt={book.title}
                      class="w-full max-w-xs mx-auto rounded-xl shadow-xl"
                    />
                  ) : (
                    <div class="w-full max-w-xs mx-auto aspect-[2/3] bg-gradient-to-br from-primary to-primary-dark rounded-xl shadow-xl flex items-center justify-center p-8">
                      <div class="text-center text-white">
                        <svg class="w-16 h-16 mx-auto mb-4 opacity-50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
                        </svg>
                        <p class="font-bold text-lg">{book.title}</p>
                      </div>
                    </div>
                  )}
                </div>

                <!-- Book Details -->
                <div class="lg:col-span-2">
                  <h3 class="text-2xl lg:text-3xl font-bold text-primary mb-2">{book.title}</h3>
                  {book.subtitle && (
                    <p class="text-lg text-accent font-semibold mb-4">{book.subtitle}</p>
                  )}
                  <p class="text-slate-600 leading-relaxed mb-6">{book.description}</p>

                  {book.price && (
                    <p class="text-2xl font-bold text-slate-900 mb-6">{book.price}</p>
                  )}

                  {book.purchaseLink && book.purchaseLink !== '#' ? (
                    <a
                      href={book.purchaseLink}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="inline-flex items-center gap-2 px-6 py-3 bg-accent hover:bg-accent-light text-white font-semibold rounded-xl transition-colors"
                    >
                      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" />
                      </svg>
                      Purchase Book
                    </a>
                  ) : (
                    <a
                      href={createPageUrl('Contact')}
                      class="inline-flex items-center gap-2 px-6 py-3 bg-primary hover:bg-primary-dark text-white font-semibold rounded-xl transition-colors"
                    >
                      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
                      </svg>
                      Inquire About Book
                    </a>
                  )}
                </div>
              </div>
            </Card>
          ))}
        </div>

        <!-- Inspirational Quote -->
        <div class="mt-12 text-center">
          <blockquote class="text-2xl lg:text-3xl font-medium text-primary italic max-w-3xl mx-auto">
            "Create a GREAT day and keep making GREAT even better!"
          </blockquote>
          <p class="mt-4 text-slate-500">-- Coach Aaron</p>
        </div>
      </section>

      <!-- HR Leadership Insights Section -->
      <section class="mb-20">
        <div class="flex items-center gap-4 mb-4">
          <div class="w-14 h-14 rounded-2xl bg-primary/10 flex items-center justify-center">
            <svg class="w-7 h-7 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
          </div>
          <div>
            <h2 class="text-3xl font-bold text-primary">HR Leadership Insights</h2>
            <p class="text-slate-600">Strengthening Leadership Hiring and Role Clarity</p>
          </div>
        </div>
        <p class="text-slate-600 leading-relaxed mb-8 max-w-4xl">
          HR leaders play a critical role in shaping leadership capability across organizations. From writing role descriptions that attract the right leaders to establishing clear expectations that drive accountability, HR professionals are the bridge between organizational strategy and leadership execution.
        </p>

        <div class="grid md:grid-cols-3 gap-6">
          <!-- Card 1: 7 Signs -->
          <Card class="p-6 hover:border-primary hover:shadow-lg transition-all">
            <div class="w-12 h-12 rounded-xl bg-primary/10 flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
              </svg>
            </div>
            <h3 class="text-xl font-bold text-slate-900 mb-3">The 7 Signs Your Job Description Is Costing You Leaders</h3>
            <p class="text-slate-600 mb-6 leading-relaxed">
              Discover the most common pitfalls in leadership job descriptions that drive top candidates away and learn how to fix them.
            </p>
            <Button variant="primary" size="sm" href={createPageUrl('Resources')}>
              Read More
            </Button>
          </Card>

          <!-- Card 2: Hiring Framework -->
          <Card class="p-6 hover:border-primary hover:shadow-lg transition-all">
            <div class="w-12 h-12 rounded-xl bg-accent/10 flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4" />
              </svg>
            </div>
            <h3 class="text-xl font-bold text-slate-900 mb-3">The LEAP Leadership Hiring Framework</h3>
            <p class="text-slate-600 mb-4 leading-relaxed">
              A structured approach to leadership hiring built around four pillars:
            </p>
            <ul class="space-y-2 mb-6">
              <li class="flex items-start gap-2 text-slate-600">
                <svg class="w-5 h-5 text-accent flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                Role Clarity
              </li>
              <li class="flex items-start gap-2 text-slate-600">
                <svg class="w-5 h-5 text-accent flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                Accountability
              </li>
              <li class="flex items-start gap-2 text-slate-600">
                <svg class="w-5 h-5 text-accent flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                Decision-Making Authority
              </li>
              <li class="flex items-start gap-2 text-slate-600">
                <svg class="w-5 h-5 text-accent flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                Alignment
              </li>
            </ul>
          </Card>

          <!-- Card 3: Role Scorecard -->
          <Card class="p-6 hover:border-primary hover:shadow-lg transition-all">
            <div class="w-12 h-12 rounded-xl bg-primary/10 flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
              </svg>
            </div>
            <h3 class="text-xl font-bold text-slate-900 mb-3">Leadership Role Scorecard</h3>
            <p class="text-slate-600 mb-6 leading-relaxed">
              Evaluate leadership roles against the LEAP framework to ensure clarity, accountability, and alignment before, during, and after the hiring process.
            </p>
            <Button variant="primary" size="sm" href={createPageUrl('Practice')}>
              Take the Scorecard
            </Button>
          </Card>
        </div>
      </section>

      <!-- Leadership Pulse Insights Section -->
      <section class="mb-20">
        <div class="flex items-center gap-4 mb-4">
          <div class="w-14 h-14 rounded-2xl bg-accent/10 flex items-center justify-center">
            <svg class="w-7 h-7 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" />
            </svg>
          </div>
          <div class="flex items-center gap-3">
            <h2 class="text-3xl font-bold text-primary">Leadership Pulse Insights</h2>
            <span class="px-3 py-1 bg-accent text-white text-xs font-bold rounded-full uppercase tracking-wider">New</span>
          </div>
        </div>
        <p class="text-slate-600 mb-2">What Leaders Are Experiencing Right Now</p>

        <!-- Survey Question -->
        <div class="bg-slate-50 rounded-2xl p-8 mb-8 border border-slate-100">
          <p class="text-lg font-semibold text-primary mb-6">
            "What leadership challenge is currently the most significant within your organization?"
          </p>

          <!-- Results Bars -->
          <div class="space-y-4">
            {pulseData.map((item) => (
              <div>
                <div class="flex items-center justify-between mb-1">
                  <span class="text-sm font-medium text-slate-700">{item.label}</span>
